<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:padding="24dp"
    tools:context=".MainActivity">

    <!--
        LOGIN FORM CONTAINER
        Uses layout_centerInParent to float in the middle of the screen.
        All children stack vertically inside this LinearLayout.
    -->
    <LinearLayout
        android:id="@+id/loginContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_centerInParent="true"
        android:orientation="vertical"
        android:visibility="visible">

        <!-- App Logo — centered horizontally at top of form -->

        <!-- Title — below logo -->

        <ImageView
            android:id="@+id/ivAppLogo"
            android:layout_width="110dp"
            android:layout_height="110dp"
            android:layout_gravity="center_horizontal"
            android:background="@drawable/circle_background"
            android:contentDescription="@string/app_logo_desc"
            android:padding="6dp"
            android:src="@android:mipmap/sym_def_app_icon" />

        <TextView
            android:id="@+id/tvTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="16dp"
            android:text="@string/welcome_back"
            android:textSize="28sp"
            android:textStyle="bold"
            android:textColor="@color/primary_dark" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="4dp"
            android:text="@string/sign_in_to_continue"
            android:textSize="14sp"
            android:textColor="@color/text_secondary" />

        <!-- Username EditText — below title, full width with padding -->
        <EditText
            android:id="@+id/etUsername"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="28dp"
            android:background="@drawable/input_background"
            android:hint="@string/hint_username"
            android:inputType="text"
            android:padding="14dp"
            android:textSize="15sp"
            android:textColor="@color/black"
            android:textColorHint="@color/text_secondary"
            android:autofillHints="username" />

        <!-- Password EditText — below username -->
        <EditText
            android:id="@+id/etPassword"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:background="@drawable/input_background"
            android:hint="@string/hint_password"
            android:inputType="textPassword"
            android:padding="14dp"
            android:textSize="15sp"
            android:textColor="@color/black"
            android:textColorHint="@color/text_secondary"
            android:autofillHints="password" />

        <!-- Forgot Password — aligned to right, below password field -->
        <TextView
            android:id="@+id/tvForgotPassword"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="end"
            android:layout_marginTop="10dp"
            android:text="@string/forgot_password"
            android:textColor="@color/link_blue"
            android:textSize="13sp"
            android:textStyle="bold" />

        <!-- Login Button — below password/forgot, centered horizontally -->
        <Button
            android:id="@+id/btnLogin"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="24dp"
            android:backgroundTint="@color/primary_dark"
            android:text="@string/btn_login"
            android:textColor="@color/white"
            android:textSize="16sp"
            android:textStyle="bold"
            android:letterSpacing="0.08" />

    </LinearLayout>

    <!--
        PROFILE CARD — initially GONE
        Positioned with layout_centerInParent; revealed on successful login.
        Contains avatar, name, email, bio, and logout button.
    -->
    <LinearLayout
        android:id="@+id/profileCard"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_centerInParent="true"
        android:orientation="vertical"
        android:background="@drawable/card_background"
        android:padding="28dp"
        android:elevation="6dp"
        android:visibility="gone">

        <!-- Avatar ImageView — centered horizontally -->
        <ImageView
            android:id="@+id/ivAvatar"
            android:layout_width="110dp"
            android:layout_height="110dp"
            android:layout_gravity="center_horizontal"
            android:src="@mipmap/ic_launcher_round"
            android:background="@drawable/circle_background"
            android:padding="6dp"
            android:contentDescription="@string/avatar_desc" />

        <!-- Name TextView — below avatar -->
        <TextView
            android:id="@+id/tvName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="18dp"
            android:text="@string/profile_name"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="@color/primary_dark" />

        <!-- Email TextView — below name -->
        <TextView
            android:id="@+id/tvEmail"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="6dp"
            android:text="@string/profile_email"
            android:textSize="14sp"
            android:textColor="@color/link_blue" />

        <!-- Divider -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="16dp"
            android:background="#E0E0E0" />

        <!-- Bio TextView — below email -->
        <TextView
            android:id="@+id/tvBio"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:text="@string/profile_bio"
            android:textSize="14sp"
            android:textColor="@color/text_secondary"
            android:gravity="center"
            android:lineSpacingExtra="4dp" />

        <!-- Logout Button — full width, below bio -->
        <Button
            android:id="@+id/btnLogout"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="28dp"
            android:backgroundTint="@color/accent_red"
            android:text="@string/btn_logout"
            android:textColor="@color/white"
            android:textSize="15sp"
            android:textStyle="bold"
            android:letterSpacing="0.08" />

    </LinearLayout>

    <!--
        LOADING PROGRESS BAR
        Centered in parent using layout_centerInParent.
        Shown briefly during login validation.
    -->
    <ProgressBar
        android:id="@+id/progressBar"
        style="?android:attr/progressBarStyleLarge"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_centerInParent="true"
        android:indeterminateTint="@color/primary"
        android:visibility="gone" />

</RelativeLayout>
